# Binary Pulse Engine environment variables
# Copy this file to .env for local development. Never commit .env.
# Values below are examples only; credential variables are intentionally blank. Do not place real secrets in this file.

# Runtime environment (optional)
# HTTP port used by the Express server. Defaults to 3000 when omitted.
# Must be an integer between 1 and 65535; invalid values stop startup.
PORT=3000
# Use development locally, production on deployed servers, test only in automated tests.
NODE_ENV=development
# Test flag used by the test suite and timeout defaults (test-only).
TEST_ENV=false

# Market data provider selector (optional)
# Supported by the server: fastforex, twelvedata, massive. Defaults to fastforex.
MARKET_DATA_PROVIDER=fastforex

# FastForex provider (FASTFOREX_API_KEY is required when using FastForex with live data)
# Example key format/comment only: use the key provided by FastForex for the account in use.
FASTFOREX_API_KEY=
FASTFOREX_BASE_URL=https://api.fastforex.io
FASTFOREX_TIMEOUT_MS=10000
FASTFOREX_SYMBOLS_FOREX=EUR/USD,GBP/USD,USD/JPY,EUR/GBP,AUD/USD,USD/CAD
FASTFOREX_SYMBOLS_CRYPTO=BTC/USD,ETH/USD,SOL/USD,XRP/USD,BNB/USD

# Gemini formatting (optional)
# Leave empty to use the built-in formatter without Gemini. Example/comment only: Gemini API key from Google AI Studio.
GEMINI_API_KEY=

# Backstage scan controls (optional)
BACKSTAGE_SCAN_ALL_TIMEOUT_MS=60000
BACKSTAGE_SCAN_ALL_COOLDOWN_MS=30000

# Analyze-market debug output (optional)
DEBUG_ANALYZE_MARKET=false

# Twelve Data provider (optional; required only when MARKET_DATA_PROVIDER=twelvedata)
# Example key format/comment only: use the API key from the Twelve Data dashboard.
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
MARKET_SYMBOLS=EUR/USD,GBP/USD,USD/JPY,EUR/GBP,AUD/USD,USD/CAD

# Massive/Polygon provider (optional; required only when MARKET_DATA_PROVIDER=massive)
# Example key format/comment only: use the API key from the Massive/Polygon dashboard.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.polygon.io
MARKET_SYMBOLS_FOREX=EUR/USD,GBP/USD,USD/JPY,EUR/GBP,AUD/USD,USD/CAD
MARKET_SYMBOLS_CRYPTO=BTC/USD,ETH/USD,SOL/USD,XRP/USD,BNB/USD

# OANDA provider endpoints (optional; required only for OANDA-backed routes/integrations)
# Example/comment only: use the token and account ID from the selected OANDA account.
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
OANDA_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,EUR_JPY,GBP_JPY,AUD_USD,USD_CAD,EUR_GBP

# Vite development server (optional; useful in constrained/CI-like environments)
DISABLE_HMR=false
